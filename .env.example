GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finance
APP_BASE_URL=http://localhost:5173
PORT=3000
# Optional — enables the Telegram cash bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_CHAT_ID=
# Optional — enables AI auto-categorisation (Reconcile). Without it, only the
# free rules engine runs. Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
# Optional — Trading 212 investments (https://docs.trading212.com/api). Generate a
# key in the app: Settings -> API. Default base is live; use demo.trading212.com for paper.
TRADING212_API_KEY=
TRADING212_BASE_URL=https://live.trading212.com
