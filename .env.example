GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finance
APP_BASE_URL=http://localhost:5173
PORT=3000
# Optional — enables the Telegram cash bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_CHAT_ID=
# Optional — enables AI auto-categorisation (Reconcile). Without it, only the
# free rules engine runs. Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
# Optional — Gmail plugin (order/receipt parsing). OAuth client from Google Cloud
# Console; add <APP_BASE_URL>/api/plugins/gmail/callback as an authorised redirect.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional — Gmail REALTIME push (see docs/gmail-realtime-setup.md). Without these,
# Gmail stays near-realtime via the scheduled /api/sync/all cron.
#   GMAIL_PUBSUB_TOPIC: full topic resource name (projects/<id>/topics/<name>)
#   GMAIL_PUSH_TOKEN:   shared secret appended to the push URL (?token=...)
GMAIL_PUBSUB_TOPIC=
GMAIL_PUSH_TOKEN=
# Background full-sync cadence in minutes (banks + investments + Gmail, re-matches
# orders, renews the Gmail watch). Default 60; set 0 to disable the scheduler.
SYNC_INTERVAL_MINUTES=60
# Optional — Trading 212 investments (https://docs.trading212.com/api). Generate a
# key+secret in the app: Settings -> API. Auth = Basic base64(keyId:secret).
# Use https://demo.trading212.com only with a paper-account key.
TRADING_212_KEY_ID=
TRADING_212_SECRET=
TRADING212_BASE_URL=https://live.trading212.com
# Optional — Bitget (crypto) investments. API key + secret + passphrase from
# Bitget -> API Management. Coins are valued via tickers (USDT) -> GBP.
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=
# BITGET_USD_GBP=0.79   # optional fixed USD->GBP rate (else fetched live)
# Optional — merchant logos (resolved & cached server-side to the bucket; served
# via /api/logo/:domain). Brandfetch publishable client ID from
# https://brandfetch.com/developers (Clearbit's free Logo API shut down
# 2025-12-08); logo.dev token is optional. Without either, logos fall back to
# DuckDuckGo favicons, then a monogram.
BRANDFETCH_CLIENT_ID=
LOGODEV_TOKEN=
# Optional — Brandfetch Brand API key (Bearer, separate from the client ID above;
# rate-limited). Enables real brand-colour avatar tinting; backfills gradually.
BRANDFETCH_API_KEY=
