generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  PERSONAL
  BUSINESS
}

enum AccountSource {
  BANK
  MANUAL
  INVESTMENT
  ASSET
  LIABILITY
}

model Requisition {
  id              String    @id
  institutionId   String
  institutionName String
  reference       String
  status          String
  createdAt       DateTime  @default(now())
  accounts        Account[]
}

model Account {
  id            String         @id
  requisition   Requisition?   @relation(fields: [requisitionId], references: [id])
  requisitionId String?
  source        AccountSource  @default(BANK)
  type          AccountType    @default(PERSONAL)
  iban          String?
  name          String?
  nickname      String?
  currency      String?
  ownerName     String?
  manualBalance Decimal?
  balanceType   String?
  interestRate  Decimal?       // annual % APR, for debts (projections / avalanche)
  priority      Int?           // manual debt payoff order (lower = pay first)
  targetPayment Decimal?       // planned next payment toward a debt (may be partial)
  debtExcluded  Boolean  @default(false) // hide from the Debt screen focus (e.g. long-term mortgage)
  provider      String?        // investment provider key, e.g. "trading212", "bitget"
  createdAt     DateTime       @default(now())
  balances      Balance[]
  transactions  Transaction[]
  syncLogs      SyncLog[]
  holdings      Holding[]
}

// A normalised investment position — equities (Trading 212) or crypto (Bitget).
model Holding {
  id        Int      @id @default(autoincrement())
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId String
  symbol    String   // provider ticker, e.g. "AAPL_US_EQ" or "BTC"
  name      String?
  quantity  Decimal
  price     Decimal  // current price (account currency)
  value     Decimal  // current value (account currency)
  cost      Decimal?
  pnl       Decimal?
  currency  String?
  updatedAt DateTime @updatedAt

  @@index([accountId])
}

model Balance {
  id            Int      @id @default(autoincrement())
  account       Account  @relation(fields: [accountId], references: [id])
  accountId     String
  type          String
  amount        Decimal
  currency      String
  referenceDate String?
  fetchedAt     DateTime @default(now())

  @@unique([accountId, type])
}

model Transaction {
  id             String   @id
  account        Account  @relation(fields: [accountId], references: [id])
  accountId      String
  bookingDate    String?
  valueDate      String?
  amount         Decimal
  currency       String
  creditorName   String?
  debtorName     String?
  remittanceInfo String?
  merchantName   String?
  category         String
  categoryOverride String?
  personKey        String?
  note             String?
  flag             String?
  debtAccountId    String?  // links a repayment to a LIABILITY account
  status         String
  raw            Json

  @@index([accountId, bookingDate])
}

model SyncLog {
  id        Int      @id @default(autoincrement())
  account   Account  @relation(fields: [accountId], references: [id])
  accountId String
  ranAt     DateTime @default(now())
  added     Int
  status    String
}

model Category {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  key           String   @unique
  group         String?
  monthlyAmount Decimal  @default(0)
  sortOrder     Int      @default(0)
  archived      Boolean  @default(false)
}

model Person {
  id        Int     @id @default(autoincrement())
  key       String  @unique
  name      String
  sortOrder Int     @default(0)
  archived  Boolean @default(false)
}

// Canonical merchant (source of truth) keyed by a normalised token. Holds the
// display name + recurring classification override; spend is aggregated from
// transactions that match the token.
model Merchant {
  token       String  @id
  name        String?
  categoryKey String?
  recurring   String  @default("auto") // auto | fixed | variable | ignore
}

// App config / feature flags (key/value).
model Setting {
  key   String @id
  value String
}

model Rule {
  id          Int      @id @default(autoincrement())
  matchText   String
  categoryKey String?
  personKey   String?
  priority    Int      @default(0)
  auto        Boolean  @default(false)
  createdAt   DateTime @default(now())
}
