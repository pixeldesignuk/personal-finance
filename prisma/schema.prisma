generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  PERSONAL
  BUSINESS
}

enum AccountSource {
  BANK
  MANUAL
  INVESTMENT
  ASSET
  LIABILITY
}

// A savings "pot": earmarks part of your existing liquid cash toward a goal
// (emergency fund, school fees…). Does not add to net worth — it partitions
// money you already hold.
model Pot {
  id        Int      @id @default(autoincrement())
  name      String
  target    Decimal?
  balance   Decimal  @default(0)
  emoji     String?
  note      String?
  sortOrder Int      @default(0)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
}

// A connected integration (currently just Gmail). Single-user, so OAuth tokens
// live here in the DB.
model Plugin {
  id           String    @id          // "gmail"
  connected    Boolean   @default(false)
  email        String?
  refreshToken String?
  accessToken  String?
  tokenExpiry  DateTime?
  lastSyncAt   DateTime?
  cursor       String?               // newest processed email epoch (incremental sync)
  watchExpiry  DateTime?             // when the current Gmail users.watch lapses
  createdAt    DateTime  @default(now())
}

// An order/receipt parsed from an email, optionally matched to a transaction.
model EmailOrder {
  id            String   @id @default(cuid())
  source        String   @default("gmail")
  messageId     String   @unique
  emailDate     DateTime?
  merchantName  String?
  merchantToken String?
  total         Decimal?
  currency      String?
  orderNumber   String?
  items         Json?
  subject       String?
  summary       String?               // short AI summary, used as the transaction note
  tags          Json?
  isRefund      Boolean  @default(false)
  transactionId String?
  matched       Boolean  @default(false)
  attachmentKey String?               // object-storage key for the original document
  createdAt     DateTime @default(now())
}

// Unified audit log for every sync (gmail / bank / investments / all): timings,
// outcome, counts, and the full audit trail (incl. AI inputs + raw responses).
model SyncRun {
  id         String    @id @default(cuid())
  source     String
  status     String    @default("running") // running | ok | error
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  summary    Json?
  error      String?
  log        Json?
}

// A recurring payment (bill) or income, detected from a merchant's spend pattern.
// One per merchant token; `status` keeps the user's confirm/ignore across re-detection.
model RecurringSchedule {
  id            String    @id @default(cuid())
  merchantToken String    @unique
  name          String?
  accountId     String?
  direction     String    @default("out")     // out (bill) | in (income)
  amount        Decimal   @default(0)
  kind          String    @default("fixed")    // fixed | variable (amount stability)
  prevAmount    Decimal?                         // prior amount, set when it recently changed (flags increases)
  cadence       String    @default("monthly")  // monthly | weekly | yearly | irregular
  dayOfMonth    Int?
  lastSeen      DateTime?
  nextDue       DateTime?
  status        String    @default("auto")     // auto | confirmed | ignored
  createdAt     DateTime  @default(now())
}

model Requisition {
  id              String    @id
  institutionId   String
  institutionName String
  institutionLogo String?
  reference       String
  status          String
  createdAt       DateTime  @default(now())
  accounts        Account[]
}

model Account {
  id            String         @id
  requisition   Requisition?   @relation(fields: [requisitionId], references: [id])
  requisitionId String?
  source        AccountSource  @default(BANK)
  type          AccountType    @default(PERSONAL)
  iban          String?
  name          String?
  nickname      String?
  currency      String?
  ownerName     String?
  manualBalance Decimal?
  excludedBalance Decimal?     // portion of the balance that isn't yours (held for others) — carved out of net worth & safe-to-spend
  informational Boolean  @default(false) // excluded from BUDGETING (income, expense, available, safe-to-spend) but still counts toward net worth
  balanceType   String?
  interestRate  Decimal?       // annual % APR, for debts (projections / avalanche)
  priority      Int?           // manual debt payoff order (lower = pay first)
  targetPayment Decimal?       // planned next payment toward a debt (may be partial)
  debtExcluded  Boolean  @default(false) // hide from the Debt screen focus (e.g. long-term mortgage)
  provider      String?        // investment provider key, e.g. "trading212", "bitget"
  createdAt     DateTime       @default(now())
  balances      Balance[]
  transactions  Transaction[]
  syncLogs      SyncLog[]
  holdings      Holding[]
}

// A normalised investment position — equities (Trading 212) or crypto (Bitget).
model Holding {
  id        Int      @id @default(autoincrement())
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId String
  symbol    String   // provider ticker, e.g. "AAPL_US_EQ" or "BTC"
  name      String?
  quantity  Decimal
  price     Decimal  // current price (account currency)
  value     Decimal  // current value (account currency)
  cost      Decimal?
  pnl       Decimal?
  currency  String?
  updatedAt DateTime @updatedAt

  @@index([accountId])
}

model Balance {
  id            Int      @id @default(autoincrement())
  account       Account  @relation(fields: [accountId], references: [id])
  accountId     String
  type          String
  amount        Decimal
  currency      String
  referenceDate String?
  fetchedAt     DateTime @default(now())

  @@unique([accountId, type])
}

model Transaction {
  id             String   @id
  account        Account  @relation(fields: [accountId], references: [id])
  accountId      String
  bookingDate    String?
  valueDate      String?
  amount         Decimal
  currency       String
  creditorName   String?
  debtorName     String?
  remittanceInfo String?
  merchantName   String?
  category         String
  categoryOverride String?
  personKey        String?
  note             String?
  flag             String?
  debtAccountId    String?  // links a repayment to a LIABILITY account
  status         String
  raw            Json
  createdAt      DateTime @default(now())   // row insert time (for "recently added")

  @@index([accountId, bookingDate])
}

model SyncLog {
  id        Int      @id @default(autoincrement())
  account   Account  @relation(fields: [accountId], references: [id])
  accountId String
  ranAt     DateTime @default(now())
  added     Int
  status    String
}

model Category {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  key           String   @unique
  group         String?
  monthlyAmount Decimal  @default(0)
  sortOrder     Int      @default(0)
  archived      Boolean  @default(false)
}

model Person {
  id        Int     @id @default(autoincrement())
  key       String  @unique
  name      String
  sortOrder Int     @default(0)
  archived  Boolean @default(false)
}

// Canonical merchant (source of truth) keyed by a normalised token. Holds the
// display name + recurring classification override; spend is aggregated from
// transactions that match the token.
model Merchant {
  token         String    @id
  name          String?
  domain        String?
  categoryKey   String?
  recurring     String    @default("auto") // auto | fixed | variable | ignore
  logoCheckedAt DateTime? // background logo resolution has run for this merchant
}

// App config / feature flags (key/value).
model Setting {
  key   String @id
  value String
}

// Curated, region-tenanted merchant directory (seeded from the Name Suggestion
// Index + Wikidata). A matched merchant gets its domain + stored logo from here,
// so we never guess a domain from a name (which mis-fires on people).
model MerchantDirectory {
  id        String   @id @default(cuid())
  region    String   @default("UK")
  name      String
  slug      String
  aliases   String[] @default([])
  domain    String?
  logoKey   String?
  color     String?
  wikidata  String?
  updatedAt DateTime @default(now())

  @@unique([region, slug])
  @@index([region])
}

// Per-domain logo cache. Logos are resolved server-side from providers
// (Brandfetch / logo.dev / DuckDuckGo), stored in the object bucket, and served
// via /api/logo/:domain. `key` is the bucket object key; NULL means "resolved,
// no logo" (negative cache, re-checked once `checkedAt` goes stale).
model LogoCache {
  domain    String   @id
  key       String?
  source    String?
  color     String?
  checkedAt DateTime @default(now())
}

model Rule {
  id          Int      @id @default(autoincrement())
  matchText   String
  categoryKey String?
  personKey   String?
  priority    Int      @default(0)
  auto        Boolean  @default(false)
  merchantId  String?  // links this rule to a Merchant (token); null = freeform keyword rule
  createdAt   DateTime @default(now())
}
